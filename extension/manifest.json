{
  "manifest_version": 3,
  "name": "Mount Polumbus HQ",
  "version": "1.0",
  "description": "Save tweets to your HQ Inspiration Vault or Repurpose queue",
  "permissions": ["activeTab", "storage", "cookies", "alarms"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*", "https://api.github.com/*", "https://gertrude-spectroscopic-nominally.ngrok-free.dev/*"],
  "background": {"service_worker": "background.js"},
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
